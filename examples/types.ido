// Types — all type forms and variable declarations
//
// compile: idot compile examples/types.idot
// run:     ./examples/types && echo $?

fn main() -> i32 {
    // Explicit type annotations
    a: i32 = 10;
    b: i32 = 20;

    // Type inference
    d := 40;

    // Immutable
    const f: i32 = 50;
    const g := 60;

    // Assignment
    a = a + 1;
    const result := a + b + d + f + g;
    // 11 + 20 + 40 + 50 + 60 = 181
    return result;
}
