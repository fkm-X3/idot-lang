// Structs — composite types, field access, struct literals
//
// compile: idot compile examples/structs.ido

Vec3 :: struct {
    x: i32,
    y: i32,
    z: i32,
}

fn dot(a: Vec3, b: Vec3) -> i32 {
    return a.x * b.x + a.y * b.y + a.z * b.z;
}

fn main() -> i32 {
    const v := Vec3{ x = 1, y = 2, z = 3 };
    const w := Vec3{ x = 4, y = 5, z = 6 };
    const d := dot(v, w);
    return d;  // 1*4 + 2*5 + 3*6 = 32
}
