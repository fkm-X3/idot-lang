// Fibonacci — functions, recursion, const
//
// compile: idot compile examples/fib.idot
// run:     ./examples/fib && echo $?

fn fib(n: i32) -> i32 {
    if n < 2 {
        return n;
    }
    return fib(n - 1) + fib(n - 2);
}

fn main() -> i32 {
    const result := fib(10);
    return result;  // exit code 55
}
