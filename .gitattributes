# Auto-detect text files and normalize to LF
* text=auto eol=lf

# Rust source
*.rs text eol=lf diff=rust

# C source (generated by compiler, gitignored but attribute for safety)
*.c text eol=lf diff=c linguist-generated=true
*.h text eol=lf diff=c

# Idot source (syntax closest to Rust)
*.idot linguist-language=Rust linguist-detectable=true linguist-vendored=false linguist-generated=false

# Config / docs
*.toml text eol=lf
*.md text eol=lf diff=markdown
*.json text eol=lf

# Shell scripts (must stay LF)
*.sh text eol=lf

# Batch files (must stay CRLF)
*.bat text eol=crlf

# Binary files
*.exe binary
*.o binary
*.obj binary
*.png binary
*.ico binary

# Cargo lock — merge conflicts are painful, mark as binary
Cargo.lock -diff
